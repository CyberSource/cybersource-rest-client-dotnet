<?xml version="1.0"?>
<package >
  <metadata>
    <id>CyberSource.Rest.Client</id>
    <version>0.0.1.63</version>
    <title>CyberSource.Rest.Client</title>
    <authors>CyberSource Corporation</authors>
    <owners>CyberSource</owners>
    <projectUrl>https://github.com/CyberSource/cybersource-rest-client-dotnet</projectUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Use this client SDK to Call CyberSource REST API's. This SDK includes generates both HTTP Signature and JWT headers (including authentication headers) for the API requests.</description>
    <releaseNotes>Upgrade to .NET 4.8, RestSharp 114, SDK-style csproj</releaseNotes>
    <dependencies>
    <group targetFramework="net48">
      <dependency id="Newtonsoft.Json" version="13.0.3"></dependency>
      <dependency id="RestSharp" version="[114.0.0]"></dependency>
      <dependency id="NLog" version="5.0.0"></dependency>
      <dependency id="CyberSource.Authentication" version="[0.0.0.29]"></dependency>
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="bin\Release\net48\cybersource-rest-client-dotnet.dll" target="lib\net48\cybersource-rest-client-dotnet.dll"/>
  </files>
</package>

