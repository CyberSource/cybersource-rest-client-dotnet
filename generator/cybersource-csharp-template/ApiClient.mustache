                _merchantRequestSettings = new MerchantRequestSettingsFactory().Create(_requestMethod, _requestTarget, null);
            }
            else
            {
                _merchantRequestSettings = new MerchantRequestSettingsFactory().Create(_requestMethod, _requestTarget, postBody.ToString());
            }

            var authenticationHeaders = CallAuthenticationHeaders(_merchantRequestSettings, isResponseMLEForApi);

            foreach (var param in authenticationHeaders)
            {
                if (param.Key == "Authorization")
                {
                    request.AddParameter("Authorization", string.Format("Bearer " + param.Value),
                        ParameterType.HttpHeader);
                }
                else
                {
                    if (request.Parameters.Any(x => string.Equals(x.Name, param.Key, StringComparison.OrdinalIgnoreCase) && x.Type == ParameterType.HttpHeader))
                    {
                        continue;
                    }
                    request.AddHeader(param.Key, param.Value);
                }
            }

            // add query parameter, if any
            // foreach(var param in queryParams)
            //     request.AddQueryParameter(param.Key, param.Value);

            // add form parameter, if any
            foreach (var param in formParams)
                request.AddParameter(param.Key, param.Value);

            // add file parameter, if any
            //foreach(var param in fileParams)
            //{
                {{#netStandard}}
                //request.AddFile(param.Value);
                {{/netStandard}}
                {{^netStandard}}
                {{^supportsUWP}}
                //request.AddFile(param.Value.Name, param.Value.FileName, param.Value.ContentType);
                {{/supportsUWP}}
                {{#supportsUWP}}
                //byte[] paramWriter = null;
                //param.Value.Writer = delegate (Stream stream) { paramWriter = ToByteArray(stream); };
                //request.AddFile(param.Value.Name, param.Value.FileName, param.Value.ContentType);
                {{/supportsUWP}}
                {{/netStandard}}
            //}

            if (postBody != null) // http body (model or byte[]) parameter
            {
                if (postBody.GetType() == typeof(string))
                {
                    if (contentType == "application/x-www-form-urlencoded")
                    {
                        var bodyParams = JsonSerializer.Deserialize<Dictionary<string, string>>((string)postBody);
                        foreach (KeyValuePair<string, string> param in bodyParams)
                        {
                            {{#netStandard}}
                            request.AddParameter(new Parameter { Value = param.Value, Type = ParameterType.GetOrPost, Name = param.Key });
                            {{/netStandard}}
                            {{^netStandard}}
                            request.AddParameter(param.Key, param.Value, ParameterType.GetOrPost);
                            {{/netStandard}}
                        }
                    }
                    else if (contentType.Contains("multipart/form-data"))
                    {
                        request.AddBody(postBody, "multipart/form-data");
                        request.AddHeader("Content-Type", contentType); //required to set in case of file params
                    }
                    else
                    {
                        {{#netStandard}}
                        // request.AddParameter(new Parameter { Value = postBody, Type = ParameterType.RequestBody, ContentType = "application/json" });
                        request.AddJsonBody(postBody);
                        {{/netStandard}}
                        {{^netStandard}}
                        // request.AddParameter("application/json", postBody, ParameterType.RequestBody);
                        request.AddJsonBody(postBody);
                        {{/netStandard}}
                    }
                }
                else if (postBody.GetType() == typeof(byte[]))
                {
                    {{#netStandard}}
                    request.AddParameter(new Parameter { Value = postBody, Type = ParameterType.RequestBody, ContentType = contentType });
                    {{/netStandard}}
                    {{^netStandard}}
                    request.AddParameter(contentType, postBody, ParameterType.RequestBody);
                    {{/netStandard}}
                }
            }

            return request;
        }

        /// <summary>
        /// Gets the RestClientOptions based on the merchant network settings and merchant credential settings,
        /// including proxy configuration and client certificate configuration if applicable.
        /// </summary>
        /// <param name="merchantNetworkSettings">Object of IMerchantNetworkSettings containing network settings</param>
        /// <param name="merchantCredentialSettings">Object of IMerchantCredentialSettings containing merchant credentials</param>
        /// <param name="userAgent">HTTP User Agent</param>
        /// <param name="timeout">HTTP timeout (milliseconds)</param>
        /// <returns>RestClientOptions</returns>
        private RestClientOptions GetRestClientOptions(IMerchantNetworkSettings merchantNetworkSettings, IMerchantCredentialSettings merchantCredentialSettings, string userAgent, TimeSpan timeout)
        {
            RestClientOptions clientOptions = new RestClientOptions();

            clientOptions.UserAgent = userAgent;
            clientOptions.Timeout = timeout;

            IWebProxy webProxy = null;

            if (merchantNetworkSettings.UseProxy != null)
            {
                if (bool.Parse(merchantNetworkSettings.UseProxy))
                {
                    if (!string.IsNullOrWhiteSpace(merchantNetworkSettings.ProxyAddress) && int.TryParse(merchantNetworkSettings.ProxyPort, out int proxyPortTest))
                    {
                        WebProxy proxy = new WebProxy(merchantNetworkSettings.ProxyAddress, proxyPortTest);

                        if (!string.IsNullOrWhiteSpace(merchantNetworkSettings.ProxyUsername) && !string.IsNullOrWhiteSpace(merchantNetworkSettings.ProxyPassword))
                        {
                            proxy.Credentials = new NetworkCredential(merchantNetworkSettings.ProxyUsername, merchantNetworkSettings.ProxyPassword);
                        }

                        webProxy = proxy;
                    }
                }
            }

            if (webProxy != null)
            {
                clientOptions.Proxy = webProxy;
            }

            if (Equals(bool.Parse(merchantCredentialSettings.EnableClientCert), true))
            {
                string clientCertDirectory = merchantCredentialSettings.ClientCertDirectory;
                string clientCertFile = merchantCredentialSettings.ClientCertFile;
                SecureString clientCertPassword = new SecureString();

                foreach (char c in merchantCredentialSettings.ClientCertPassword)
                {
                    clientCertPassword.AppendChar(c);
                }
                clientCertPassword.MakeReadOnly();

                string fileName = Path.Combine(clientCertDirectory, clientCertFile);

                // Importing Certificates
                var certificate = new X509Certificate2(fileName, clientCertPassword);
                clientCertPassword.Dispose();
                clientOptions.ClientCertificates = new X509CertificateCollection { certificate };
            }

            if (!string.IsNullOrWhiteSpace(merchantCredentialSettings.IntermediateHost))
            {
                //change with intermediate hostname if present
                //supporting both for http or https for intermediate url
                if (merchantCredentialSettings.IntermediateHost.StartsWith("http://") || merchantCredentialSettings.IntermediateHost.StartsWith("https://"))
                {
                    //RestClient = new RestClient(merchantConfig.IntermediateHost);
                    clientOptions.BaseUrl = new Uri(merchantCredentialSettings.IntermediateHost);
                }
                else
                {
                    //RestClient = new RestClient("https://" + merchantConfig.IntermediateHost);
                    clientOptions.BaseUrl = new Uri("https://" + merchantCredentialSettings.IntermediateHost);
                }
            }
            else
            {
                //RestClient = new RestClient("https://" + merchantConfig.HostName);
                clientOptions.BaseUrl = new Uri("https://" + merchantCredentialSettings.HostName);
            }

            return clientOptions;
        }
