        /// <param name="merchantRequestSettings">Per-request settings (method, target, payload).</param>
        /// <param name="isResponseMLEForApi">Whether the response is expected to be MLE-encrypted.</param>
        /// <returns>A new dictionary of authentication headers for this request only.</returns>
        public Dictionary<string, string> CallAuthenticationHeaders(IMerchantRequestSettings merchantRequestSettings, bool isResponseMLEForApi = false)
        {
            var authorize = new Authorize(_merchantCredentialSettings, merchantRequestSettings, _merchantMLESettings);

            //these are the Request Headers to be sent along with the HTTP Request
            var authenticationHeaders = new Dictionary<string, string>();

            if (_merchantCredentialSettings.AuthenticationType.Equals("JWT", StringComparison.InvariantCultureIgnoreCase))
            {
                //generate token and set JWT token headers
                var jwtToken = authorize.GetToken(isResponseMLEForApi);
                authenticationHeaders.Add("Authorization", jwtToken.BearerToken);
            }
            else if (_merchantCredentialSettings.AuthenticationType.Equals("HTTP_SIGNATURE", StringComparison.InvariantCultureIgnoreCase))
            {
                //generate signature and set HTTP Signature headers
                var httpSign = authorize.GetSignature();
                authenticationHeaders.Add("v-c-merchant-id", httpSign.MerchantId);
                authenticationHeaders.Add("Date", httpSign.GmtDateTime);
                authenticationHeaders.Add("Host", httpSign.HostName);
                authenticationHeaders.Add("Signature", httpSign.SignatureParam);

                if (merchantRequestSettings.RequestType.Equals("POST", StringComparison.InvariantCultureIgnoreCase) || merchantRequestSettings.RequestType.Equals("PUT", StringComparison.InvariantCultureIgnoreCase) || merchantRequestSettings.RequestType.Equals("PATCH", StringComparison.InvariantCultureIgnoreCase))
                {
                    authenticationHeaders.Add("Digest", httpSign.Digest);
                }
            }
            else if (_merchantCredentialSettings.AuthenticationType.Equals("OAUTH", StringComparison.InvariantCultureIgnoreCase))
            {
                var oAuthToken = authorize.GetOAuthToken();
                authenticationHeaders.Add("Authorization", oAuthToken.AccessToken);
            }

            if (!string.IsNullOrEmpty(_merchantNetworkSettings.SdkClientId))
            {
                authenticationHeaders.Add("v-c-client-id", _merchantNetworkSettings.SdkClientId);
            }

            // Add SDK telemetry headers
            if (!string.IsNullOrEmpty(_merchantCredentialSettings.MerchantId))
            {
                authenticationHeaders.Add("v-c-sdk-telemetry-merchant-id", _merchantCredentialSettings.MerchantId);
            }

            if (_merchantNetworkSettings.IsSDK)
            {
                authenticationHeaders.Add("v-c-sdk-telemetry-mcp", "true");
            }

            // if (!string.IsNullOrEmpty(Configuration.SolutionId))
            // {
            //     authenticationHeaders.Add("v-c-solution-id", Configuration.SolutionId);
            // }

            return authenticationHeaders;
        }
